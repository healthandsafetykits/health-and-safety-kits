---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  relatedPosts?: CollectionEntry<'posts'>[];
}

const { post, relatedPosts = [] } = Astro.props;
const { title, description, date, dateModified, tags, ogImage } = post.data;

const siteUrl = 'https://healthandsafetykits.com';
const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 230));

// Trade-aware CTA: match post tags to the most relevant kit
const tradeCtas: Record<string, { label: string; href: string; copy: string }> = {
  'cleaning': {
    label: 'View Cleaning Kit',
    href: '/kits/cleaning/',
    copy: 'Our Cleaning Business Kit includes 19 pre-filled documents — risk assessments, COSHH assessments for 8 chemicals, H&S policy, and training materials. All tailored for UK and Ireland regulations. From £49.',
  },
  'landscaping': {
    label: 'View Landscaping Kit',
    href: '/kits/landscaping/',
    copy: 'Our Landscaping Business Kit includes 19 pre-filled documents — risk assessments, COSHH assessments for 8 chemicals, H&S policy, and training materials. All tailored for UK and Ireland regulations. From £49.',
  },
  'beauty': {
    label: 'View Beauty Salon Kit',
    href: '/kits/beauty/',
    copy: 'Our Beauty Salon Kit includes 19 pre-filled documents — risk assessments, COSHH assessments for 8 chemicals, H&S policy, and training materials. All tailored for UK and Ireland regulations. From £49.',
  },
  'dog-grooming': {
    label: 'View Dog Grooming Kit',
    href: '/kits/dog-grooming/',
    copy: 'Our Dog Grooming Kit includes 19 pre-filled documents — risk assessments, COSHH assessments for 8 chemicals, H&S policy, and training materials. All tailored for UK and Ireland regulations. From £49.',
  },
};
const matchedTrade = tags.find((t: string) => t in tradeCtas);
const cta = matchedTrade ? tradeCtas[matchedTrade] : {
  label: 'View All Kits',
  href: '/kits/',
  copy: 'Our trade-specific compliance kits include 19 pre-filled documents each — risk assessments, COSHH assessments, H&S policies, and training materials. All tailored for UK and Ireland regulations. From £49.',
};

const publishedDate = new Date(date);
const modifiedDate = dateModified ? new Date(dateModified) : undefined;
const formattedDate = publishedDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const formattedModified = modifiedDate?.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": publishedDate.toISOString(),
  ...(modifiedDate && { "dateModified": modifiedDate.toISOString() }),
  "author": {
    "@type": "Person",
    "name": "Jim Health",
    "jobTitle": "Health & Safety Compliance Specialist",
    "url": `${siteUrl}/about/`,
    "sameAs": [
      "https://www.linkedin.com/company/health-and-safety-kits/",
      "https://x.com/HandSKits",
    ],
  },
  "publisher": {
    "@type": "Organization",
    "name": "Health and Safety Kits",
    "url": siteUrl,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/images/healthandsafetykits-og.png`,
    },
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/blog/${post.id}/`,
  },
  ...(ogImage && { "image": ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}` }),
  "wordCount": wordCount,
  "articleSection": tags[0] || "Health and Safety",
  "keywords": tags.join(', '),
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["article h1", "article .prose p:first-of-type"],
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${siteUrl}/blog/` },
    { "@type": "ListItem", "position": 3, "name": title, "item": `${siteUrl}/blog/${post.id}/` },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImage}
  publishedTime={publishedDate.toISOString()}
  modifiedTime={modifiedDate?.toISOString()}
  tags={tags}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <article class="blog-post">
    <div class="container" style="max-width: 780px;">

      <!-- Breadcrumbs -->
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/blog/">Blog</a>
        <span aria-hidden="true">/</span>
        <span>{title}</span>
      </nav>

      <!-- Article header -->
      <header class="post-header">
        <div class="post-meta">
          <time datetime={publishedDate.toISOString()}>{formattedDate}</time>
          {formattedModified && (
            <span class="updated">Updated: {formattedModified}</span>
          )}
          <span class="reading-time">{readingTime} min read</span>
        </div>
        <h1>{title}</h1>
        <p class="post-author">By <a href="/about/">Jim Health</a>, Health &amp; Safety Compliance Specialist</p>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => (
              <a href={`/tags/${tag}/`} class="tag">{tag}</a>
            ))}
          </div>
        )}
      </header>

      <!-- Article body -->
      <div class="prose">
        <slot />
      </div>

      <!-- CTA -->
      <aside class="post-cta">
        <h3>Get Compliant in 60 Minutes</h3>
        <p>{cta.copy}</p>
        <div class="cta-buttons">
          <a href={cta.href} class="btn btn-primary">{cta.label}</a>
          <a href="/free-sample/" class="btn btn-secondary">Download Free Sample</a>
        </div>
      </aside>

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <section class="related-posts">
          <h3>Related Articles</h3>
          <div class="related-grid">
            {relatedPosts.map(related => (
              <a href={`/blog/${related.id}/`} class="related-card">
                <span class="related-title">{related.data.title}</span>
                <span class="related-desc">{related.data.description}</span>
              </a>
            ))}
          </div>
        </section>
      )}

    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: 2rem 0 3rem;
  }

  .breadcrumbs {
    font-size: 0.825rem;
    color: #6b7280;
    margin-bottom: 2rem;
  }

  .breadcrumbs a {
    color: #6b7280;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: #2563eb;
    text-decoration: underline;
  }

  .breadcrumbs span[aria-hidden] {
    margin: 0 0.4rem;
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-author {
    font-size: 0.9rem;
    color: #4b5563;
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  .post-author a {
    color: #2563eb;
    text-decoration: none;
  }

  .post-author a:hover {
    text-decoration: underline;
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
    color: #6b7280;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .post-meta .updated {
    color: #059669;
  }

  .reading-time::before {
    content: '\00b7';
    margin-right: 1rem;
  }

  .post-header h1 {
    font-size: 2.25rem;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    background: #eff6ff;
    color: #2563eb;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s;
  }

  .tag:hover {
    background: #dbeafe;
    text-decoration: none;
  }

  /* Prose / article body */
  .prose {
    line-height: 1.75;
    color: #1f2937;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .prose :global(h3) {
    font-size: 1.2rem;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.35rem;
  }

  .prose :global(strong) {
    color: #111827;
  }

  .prose :global(a) {
    color: #2563eb;
    text-decoration: underline;
  }

  .prose :global(a:hover) {
    color: #1d4ed8;
  }

  .prose :global(blockquote) {
    border-left: 3px solid #2563eb;
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: #f8fafc;
    color: #374151;
    font-style: normal;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 0.6rem 0.75rem;
    border: 1px solid #e5e7eb;
    text-align: left;
  }

  .prose :global(th) {
    background: #f9fafb;
    font-weight: 600;
  }

  .prose :global(code) {
    background: #f3f4f6;
    padding: 0.15em 0.35em;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  /* TL;DR box — use blockquote with "TL;DR" or a custom class */
  .prose :global(.tldr),
  .prose :global(blockquote:first-child) {
    background: linear-gradient(135deg, #eff6ff 0%, #ecfdf5 100%);
    border-left: 4px solid #2563eb;
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    margin: 0 0 2rem 0;
  }

  /* CTA section */
  .post-cta {
    margin-top: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #eff6ff 0%, #ecfdf5 100%);
    border-radius: 0.75rem;
    text-align: center;
  }

  .post-cta h3 {
    margin-bottom: 0.5rem;
    font-size: 1.35rem;
  }

  .post-cta p {
    color: #4b5563;
    margin-bottom: 1.25rem;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Related posts */
  .related-posts {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
  }

  .related-posts h3 {
    margin-bottom: 1rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .related-card:hover {
    border-color: #2563eb;
    box-shadow: 0 1px 4px rgba(37, 99, 235, 0.1);
    text-decoration: none;
  }

  .related-title {
    font-weight: 600;
    color: #1a1a1a;
    font-size: 0.925rem;
  }

  .related-desc {
    font-size: 0.8rem;
    color: #6b7280;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 1.6rem;
    }
  }
</style>

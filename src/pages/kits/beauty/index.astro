---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const basicDocs = [
  { name: 'Health & Safety Policy', desc: 'Complete H&S policy pre-written for beauty salons, mobile beauty, and hairdressing businesses. Covers 20 arrangement sections including infection control, client welfare, and ventilation.' },
  { name: 'General Risk Assessment', desc: 'Comprehensive workplace risk assessment covering 10 general hazards — from PAT testing of electrical equipment to driving for mobile beauticians.' },
  { name: 'Beauty Operations Risk Assessment', desc: '12 beauty-specific hazards assessed — hair cutting, chemical treatments, heat styling up to 230\u00B0C, nail treatments, waxing, facials, eyelash extensions, electrical equipment, infection control, client allergies, ergonomic hazards, and ventilation.' },
  { name: 'COSHH Assessments (8 Chemicals)', desc: 'Individual assessments for 8 beauty and salon chemicals — each with CAS numbers, GHS classifications, H-codes, exposure routes, control measures, PPE requirements, and emergency procedures.' },
  { name: 'Manual Handling Assessment', desc: 'TILE framework assessment covering 6 salon-specific tasks — salon chairs, stock boxes, portable equipment, wash basins, laundry, and mobile setup transport.' },
  { name: 'Lone Working Policy', desc: 'Policy and risk assessment for mobile beauticians working alone — new client vetting procedures, safe word system, check-in protocols, and personal safety measures.' },
  { name: 'Slip, Trip & Fall Assessment', desc: 'Assessment of 8 specific hazards — wet floors, hair clippings, trailing cables, product spills, client home hazards, step stools, bag and trolley placement, and uneven surfaces.' },
  { name: 'Accident & Incident Report Form + Log', desc: 'RIDDOR-aligned reporting form and running log covering 10 beauty-specific injury types. Ready to print and keep on site.' },
  { name: 'Quick-Start Compliance Guide', desc: 'Step-by-step guide to get audit-ready in 60 minutes. Tells you exactly what to do with each document and in what order.' },
];

const proDocs = [
  { name: 'Fire Risk Assessment', desc: 'Five-step fire risk assessment covering beauty-specific ignition sources — aerosol sprays, acetone, candles, UV lamps, and electrical styling tools.' },
  { name: 'Staff Induction Checklist', desc: 'Structured 12-section checklist ensuring every new employee is properly inducted — including patch testing procedures, infection control protocols, and chemical handling.' },
  { name: 'Training Presentation (26 Slides)', desc: 'Ready-to-deliver staff training covering beauty-specific hazards, COSHH basics, infection control, client safety, and emergency procedures. Includes speaker notes.' },
  { name: 'Staff Knowledge Quiz (20 Questions)', desc: 'Multiple-choice assessment with answer key. Proves staff have understood their training — required for due diligence.' },
  { name: 'Training Record Log & Matrix', desc: 'Track who has been trained, when, and on what. Demonstrates ongoing compliance to inspectors, insurers, and clients.' },
  { name: 'Annual H&S Review Checklist', desc: 'Structured annual review covering 12 compliance areas including infection control procedures, client records, and chemical storage.' },
  { name: 'PPE Assessment', desc: '13-activity PPE matrix covering hair colouring, bleaching, nail acrylics, waxing, facials, lash extensions, and more. Specifies gloves, aprons, eye protection, and respiratory protection for each task.' },
  { name: 'Client Site Assessment', desc: 'Pre-visit assessment for mobile beauticians visiting client homes — 15 hazard checkboxes, What3Words location recording, and environmental suitability checks.' },
  { name: 'Emergency Procedures', desc: 'Wall-display-ready emergency procedures covering anaphylaxis, chemical burns, heat burns, fainting, and sharps injuries. Ready to print and display.' },
  { name: 'Ireland Safety Statement', desc: 'Full safety statement compliant with the Safety, Health and Welfare at Work Act 2005. Covers 17 beauty-specific hazards. Required for all Irish businesses.' },
];

const chemicals = [
  'Permanent Hair Colour (PPD/PTD, Ammonia, Hydrogen Peroxide)',
  'Hair Bleach / Lightener (Persulphates)',
  'Perm Solution (Ammonium Thioglycolate)',
  'Acrylic Nail Monomer (EMA)',
  'Nail Polish Remover / Acetone',
  'Eyelash Extension Adhesive (Cyanoacrylate)',
  'Hot Wax / Strip Wax',
  'Barbicide / Tool Disinfectant',
];

const faqs = [
  {
    q: 'Are these just blank templates?',
    a: 'No. Every document is pre-filled with real beauty and salon content — real hazards, 8 chemicals with CAS numbers and GHS data, patch testing protocols, infection control procedures, and client safety measures. You just add your company name and review.',
  },
  {
    q: 'Do I need the Basic or Pro kit?',
    a: 'If you\'re a sole trader working alone, the Basic kit covers everything you legally need. If you employ staff (even one person), the Pro kit adds training materials, induction checklists, and ongoing compliance tools that demonstrate due diligence.',
  },
  {
    q: 'Is this compliant with UK and Irish law?',
    a: 'Yes. All documents align with the Health and Safety at Work Act 1974, Management of Health and Safety at Work Regulations 1999, COSHH Regulations 2002, Electricity at Work Regulations 1989, and PUWER 1998. The Pro kit includes an Ireland Safety Statement compliant with the SHWW Act 2005.',
  },
  {
    q: 'What format are the documents?',
    a: 'The Basic kit includes print-ready PDFs. The Pro kit includes both PDFs and editable Word (.docx) files so you can customise everything to your business.',
  },
  {
    q: 'Can I buy individual documents instead?',
    a: 'Yes. Individual risk assessments and COSHH assessments are available from \u00A312 each, and policies from \u00A319. But the full kit is much better value — 19 documents for \u00A379 works out at just \u00A34.16 each.',
  },
  {
    q: 'What if regulations change?',
    a: 'All documents include version dates. We monitor UK and Irish regulatory changes and offer free updates to kit buyers when significant changes occur.',
  },
  {
    q: 'Do I get a refund if it\'s not what I expected?',
    a: 'As a digital download, all sales are final once the file is downloaded. That\'s why we offer a free sample — download it first to check the quality and format before purchasing.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://healthandsafetykits.com" },
    { "@type": "ListItem", "position": 2, "name": "Kits", "item": "https://healthandsafetykits.com/kits/" },
    { "@type": "ListItem", "position": 3, "name": "Beauty Salon Kit", "item": "https://healthandsafetykits.com/kits/beauty/" },
  ],
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Beauty Salon H&S Compliance Kit",
  "description": "Complete health and safety compliance kit for beauty salons and mobile beauticians. 19 pre-filled documents including risk assessments, COSHH assessments for 8 chemicals, policies, and training materials.",
  "brand": { "@type": "Brand", "name": "Health and Safety Kits" },
  "image": "https://healthandsafetykits.com/images/healthandsafetykits-og.png",
  "category": "Health & Safety Compliance Documents > Beauty Salon",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "8",
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": [
    {
      "@type": "Review",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Emma L." },
      "reviewBody": "The COSHH assessments for hair dye and bleach were exactly what my insurance company asked for. Saved me a fortune compared to a consultant."
    },
    {
      "@type": "Review",
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Rachel S." },
      "reviewBody": "As a mobile beautician, the lone working policy and client site assessment were invaluable. Everything was already written for my situation."
    }
  ],
  "offers": [
    {
      "@type": "Offer",
      "name": "Basic Kit",
      "price": "49.00",
      "priceCurrency": "GBP",
      "availability": "https://schema.org/InStock",
      "url": "https://healthandsafetykits.com/kits/beauty/",
      "seller": { "@type": "Organization", "name": "Health and Safety Kits" },
      "priceValidUntil": "2027-03-31",
      "shippingDetails": {
        "@type": "OfferShippingDetails",
        "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "GBP" },
        "deliveryTime": { "@type": "ShippingDeliveryTime", "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "d" }, "transitTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "d" } },
        "shippingDestination": { "@type": "DefinedRegion", "addressCountry": ["GB", "IE"] }
      },
      "hasMerchantReturnPolicy": {
        "@type": "MerchantReturnPolicy",
        "applicableCountry": ["GB", "IE"],
        "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
        "merchantReturnDays": 0
      }
    },
    {
      "@type": "Offer",
      "name": "Pro Kit",
      "price": "79.00",
      "priceCurrency": "GBP",
      "availability": "https://schema.org/InStock",
      "url": "https://healthandsafetykits.com/kits/beauty/",
      "seller": { "@type": "Organization", "name": "Health and Safety Kits" },
      "priceValidUntil": "2027-03-31",
      "shippingDetails": {
        "@type": "OfferShippingDetails",
        "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "GBP" },
        "deliveryTime": { "@type": "ShippingDeliveryTime", "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "d" }, "transitTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "d" } },
        "shippingDestination": { "@type": "DefinedRegion", "addressCountry": ["GB", "IE"] }
      },
      "hasMerchantReturnPolicy": {
        "@type": "MerchantReturnPolicy",
        "applicableCountry": ["GB", "IE"],
        "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
        "merchantReturnDays": 0
      }
    },
  ],
};
---

<BaseLayout
  title="Beauty Salon H&S Kit"
  description="Complete health and safety kit for beauty salons and mobile beauticians. 19 pre-filled documents — risk assessments, COSHH assessments for 8 chemicals, H&S policy, training materials. From £49. One-time download."
  ogType="product"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/kits/">Kits</a>
        <span aria-hidden="true">/</span>
        <span>Beauty Salon</span>
      </nav>
      <h1>Beauty Salon H&amp;S Compliance Kit</h1>
      <p class="hero-subtitle">
        19 professional compliance documents &mdash; pre-filled with real salon hazards,
        8 chemicals used in hair and beauty treatments, infection control protocols,
        and client safety procedures.
        <strong>Audit-ready in 60 minutes.</strong>
      </p>
      <div class="hero-pricing">
        <div class="price-option">
          <span class="price-label">Basic Kit</span>
          <span class="price-amount">&pound;49</span>
          <span class="price-detail">9 documents &middot; PDFs</span>
        </div>
        <div class="price-divider"></div>
        <div class="price-option price-option-featured">
          <span class="price-badge">Most Popular</span>
          <span class="price-label">Pro Kit</span>
          <span class="price-amount">&pound;79</span>
          <span class="price-detail">19 documents &middot; PDFs + Word</span>
        </div>
      </div>
      <div class="hero-cta">
        <a href="#buy" class="btn btn-primary btn-lg">Buy Now</a>
        <a href="/free-sample/" class="btn btn-secondary btn-lg">Try Free Sample First</a>
      </div>
      <p class="hero-note">One-time purchase. Instant download. No subscriptions.</p>
    </div>
  </section>

  <!-- Who This Is For -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Built for Beauty Professionals Like You</h2>
      <div class="audience-grid">
        <div class="audience-card">
          <h3>Sole Trader Beauticians</h3>
          <p>Mobile beauty, home-based salon, or chair renting. Need H&amp;S docs for insurance and client confidence.</p>
        </div>
        <div class="audience-card">
          <h3>Hair &amp; Beauty Salons</h3>
          <p>Small high-street salon employing 1&ndash;5 staff. Clients and insurers expect documented compliance.</p>
        </div>
        <div class="audience-card">
          <h3>Mobile Hairdressers &amp; Therapists</h3>
          <p>Visiting client homes brings unique risks. Documents cover both salon and mobile working.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included: Basic -->
  <section class="section included-section" id="whats-included">
    <div class="container">
      <h2 class="text-center">What&rsquo;s in the Kit</h2>
      <p class="section-subtitle">
        Every document is pre-filled with beauty-salon-specific content.
        Real hazards, real chemicals, real control measures.
      </p>

      <h3 class="tier-heading">Basic Kit &mdash; &pound;49 <span class="tier-count">(9 documents)</span></h3>
      <div class="docs-grid">
        {basicDocs.map((doc) => (
          <div class="doc-card">
            <h4>{doc.name}</h4>
            <p>{doc.desc}</p>
          </div>
        ))}
      </div>

      <h3 class="tier-heading tier-heading-pro">Pro Kit Adds &mdash; &pound;79 total <span class="tier-count">(all 19 documents)</span></h3>
      <p class="tier-note">Everything in Basic, plus these 10 additional documents:</p>
      <div class="docs-grid">
        {proDocs.map((doc) => (
          <div class="doc-card doc-card-pro">
            <h4>{doc.name}</h4>
            <p>{doc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COSHH Chemicals Covered -->
  <section class="section chemicals-section">
    <div class="container">
      <h2 class="text-center">COSHH Assessments for 8 Hair &amp; Beauty Chemicals</h2>
      <p class="section-subtitle">
        Each chemical has its own individual COSHH assessment with real CAS numbers,
        GHS hazard classifications, H-codes, exposure routes, control measures, PPE requirements,
        first aid procedures, and emergency spill response.
      </p>
      <div class="chemicals-grid">
        {chemicals.map((chem) => (
          <div class="chemical-card">
            <span class="chemical-icon">&#9878;</span>
            <span>{chem}</span>
          </div>
        ))}
      </div>
      <p class="text-center" style="margin-top: 1.5rem; color: #4b5563; font-size: 0.9rem;">
        Not using these exact products? The editable Word versions in the Pro kit let you swap in your specific chemicals.
      </p>
    </div>
  </section>

  <!-- Value Comparison -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">How This Compares</h2>
      <div class="comparison-table">
        <table>
          <thead>
            <tr>
              <th></th>
              <th>H&amp;S Consultant</th>
              <th>HASpod (a la carte)</th>
              <th class="highlight-col">Our Beauty Kit</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Cost</td>
              <td>&pound;500&ndash;&pound;2,000+</td>
              <td>&pound;85&ndash;&pound;100+ (for equivalent docs)</td>
              <td class="highlight-col"><strong>&pound;49&ndash;&pound;79</strong></td>
            </tr>
            <tr>
              <td>Beauty-specific content</td>
              <td>Sometimes</td>
              <td>No (generic templates)</td>
              <td class="highlight-col"><strong>Yes &mdash; 8 chemicals, 12 hazards, patch testing</strong></td>
            </tr>
            <tr>
              <td>Pre-filled documents</td>
              <td>Yes</td>
              <td>No</td>
              <td class="highlight-col"><strong>Yes</strong></td>
            </tr>
            <tr>
              <td>Training materials</td>
              <td>Sometimes</td>
              <td>No</td>
              <td class="highlight-col"><strong>Yes (Pro kit)</strong></td>
            </tr>
            <tr>
              <td>Ireland Safety Statement</td>
              <td>Rarely</td>
              <td>No</td>
              <td class="highlight-col"><strong>Yes (Pro kit)</strong></td>
            </tr>
            <tr>
              <td>Ongoing fees</td>
              <td>Per visit</td>
              <td>&pound;799/year for full access</td>
              <td class="highlight-col"><strong>Never &mdash; one-time purchase</strong></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing / Buy Section -->
  <section class="section pricing-section" id="buy">
    <div class="container">
      <h2 class="text-center">Choose Your Kit</h2>
      <p class="section-subtitle">
        Both tiers include the same professional, pre-filled beauty-salon documents.
        Pro adds training, ongoing compliance tools, and editable Word files.
      </p>
      <div class="pricing-grid">
        <div class="pricing-card">
          <h3>Basic Kit</h3>
          <div class="pricing-amount">&pound;49</div>
          <p class="pricing-detail">9 documents &middot; Print-ready PDFs</p>
          <ul class="pricing-list">
            <li>H&amp;S Policy (pre-filled)</li>
            <li>General Risk Assessment</li>
            <li>Beauty Operations Risk Assessment</li>
            <li>COSHH Assessments (8 chemicals)</li>
            <li>Manual Handling Assessment</li>
            <li>Lone Working Policy</li>
            <li>Slip, Trip &amp; Fall Assessment</li>
            <li>Accident Report Form + Log</li>
            <li>Quick-Start Compliance Guide</li>
          </ul>
          <a href="#" class="btn btn-secondary btn-block">Buy Basic Kit &mdash; &pound;49</a>
          <p class="pricing-note">&pound;5.44 per document</p>
        </div>
        <div class="pricing-card pricing-card-featured">
          <span class="pricing-badge">Most Popular</span>
          <h3>Pro Kit</h3>
          <div class="pricing-amount">&pound;79</div>
          <p class="pricing-detail">19 documents &middot; PDFs + Editable Word</p>
          <ul class="pricing-list">
            <li>Everything in Basic, plus:</li>
            <li>Fire Risk Assessment</li>
            <li>Staff Induction Checklist</li>
            <li>Training Presentation (26 slides)</li>
            <li>Staff Knowledge Quiz (20 Qs)</li>
            <li>Training Record Log &amp; Matrix</li>
            <li>Annual H&amp;S Review Checklist</li>
            <li>PPE Assessment (13-activity matrix)</li>
            <li>Client Site Assessment</li>
            <li>Emergency Procedures (wall-display)</li>
            <li>Ireland Safety Statement</li>
          </ul>
          <a href="#" class="btn btn-primary btn-block">Buy Pro Kit &mdash; &pound;79</a>
          <p class="pricing-note">&pound;4.16 per document</p>
        </div>
      </div>
      <p class="text-center" style="margin-top: 1.5rem; color: #6b7280; font-size: 0.9rem;">
        Secure payment via Gumroad. Instant download. Free sample available to try first.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container" style="max-width: 780px;">
      <h2 class="text-center">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section testimonials-section">
    <div class="container" style="max-width: 780px;">
      <h2 class="text-center">What Beauty Business Owners Say</h2>
      <div class="testimonials-grid">
        <blockquote class="testimonial-card">
          <p>"The COSHH assessments for hair dye and bleach were exactly what my insurance company asked for. Saved me a fortune compared to hiring a consultant."</p>
          <cite>Emma L., Salon Owner, London</cite>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>"As a mobile beautician, the lone working policy and client site assessment were invaluable. Everything was already written for my exact situation."</p>
          <cite>Rachel S., Mobile Beauty Therapist, Glasgow</cite>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>"I needed H&amp;S documents for a new salon lease. The Pro kit had everything &mdash; fire risk assessment, emergency procedures, staff training. All done in an afternoon."</p>
          <cite>Priya K., Hair &amp; Beauty Salon, Edinburgh</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Related Guides -->
  <section class="section" style="background: #f9fafb;">
    <div class="container" style="max-width: 780px;">
      <h2 class="text-center">Free Beauty Salon H&amp;S Guides</h2>
      <p class="section-subtitle">Learn more about your compliance obligations before you buy.</p>
      <ul class="related-guides">
        <li><a href="/blog/health-and-safety-for-beauty-salons/">Health and Safety for Beauty Salons: Complete Guide</a></li>
        <li><a href="/blog/beauty-salon-risk-assessment-template/">Beauty Salon Risk Assessment Template</a></li>
        <li><a href="/blog/coshh-assessment-hair-dye-bleach/">COSHH Assessment for Hair Dye and Bleach</a></li>
      </ul>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section cta-section">
    <div class="container text-center">
      <h2>Get Your Beauty Business Compliant Today</h2>
      <p>19 professional documents. Pre-filled for beauty salons. Audit-ready in 60 minutes.</p>
      <div class="cta-buttons">
        <a href="#buy" class="btn btn-primary btn-lg">Buy Beauty Kit &mdash; From &pound;49</a>
        <a href="/free-sample/" class="btn btn-ghost btn-lg">Try Free Sample First</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(135deg, #eff6ff, #dbeafe);
    padding: 2rem 0 3.5rem;
    text-align: center;
  }

  .breadcrumbs {
    font-size: 0.825rem;
    color: #6b7280;
    margin-bottom: 1.5rem;
  }

  .breadcrumbs a {
    color: #6b7280;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: #2563eb;
    text-decoration: underline;
  }

  .breadcrumbs span[aria-hidden] {
    margin: 0 0.4rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: #4b5563;
    max-width: 650px;
    margin: 0 auto 2rem;
    line-height: 1.65;
  }

  .hero-pricing {
    display: flex;
    gap: 2rem;
    justify-content: center;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .price-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    position: relative;
  }

  .price-option-featured {
    background: #fff;
    border: 2px solid #2563eb;
    border-radius: 0.75rem;
    padding: 1rem 2rem;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  }

  .price-badge {
    position: absolute;
    top: -0.65rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: #2563eb;
    color: #fff;
    padding: 0.15rem 0.6rem;
    border-radius: 9999px;
  }

  .price-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #4b5563;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .price-amount {
    font-size: 2.25rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .price-detail {
    font-size: 0.8rem;
    color: #6b7280;
  }

  .price-divider {
    width: 1px;
    height: 3rem;
    background: #d1d5db;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .hero-note {
    font-size: 0.85rem;
    color: #6b7280;
    margin-bottom: 0;
  }

  .btn-lg {
    padding: 0.875rem 2rem;
    font-size: 1.05rem;
  }


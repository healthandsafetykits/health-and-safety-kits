---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const basicDocs = [
  { name: 'Health & Safety Policy', desc: 'Complete H&S policy pre-written for dog grooming and pet services. Covers animal handling, bite prevention, zoonotic disease control, noise exposure (80\u2013100 dB), employee responsibilities, and emergency procedures.' },
  { name: 'General Risk Assessment', desc: 'Comprehensive workplace risk assessment covering 10 general hazards — including visitors with dogs on premises and mobile groomers driving between clients.' },
  { name: 'Dog Grooming Operations Risk Assessment', desc: '13 grooming-specific hazards assessed — dog bites/scratches, lifting/restraining dogs (2\u201380 kg), clipper/scissor injuries, bathing hazards, high-velocity dryer noise (85\u2013110 dB), grooming table/noose safety, nail clipping, ear cleaning, zoonotic diseases, aggressive animals, allergic reactions, slips/trips, and mobile van hazards.' },
  { name: 'COSHH Assessments (8 Chemicals)', desc: 'Individual assessments for 8 chemicals used in dog grooming — each with real H-codes, GHS classifications, exposure routes, control measures, PPE requirements, and emergency procedures.' },
  { name: 'Manual Handling Assessment', desc: 'TILE framework assessment covering 7 tasks specific to dog grooming — lifting small/medium/large dogs, restraining animals, moving mobile equipment, handling stock, and van loading. Includes live-animal unpredictable load guidance with 1.5\u20132\u00d7 weight multiplier.' },
  { name: 'Lone Working Policy', desc: 'Policy and risk assessment for groomers working alone — check-in procedures, emergency protocols, personal safety measures. Prohibits grooming known-aggressive dogs when working alone.' },
  { name: 'Slip, Trip & Fall Assessment', desc: 'Assessment of 8 slip, trip, and fall hazards specific to grooming environments — wet floors, dog hair accumulation, shampoo spills, leads as trip hazards, dogs pulling handlers, uneven surfaces, and cluttered areas.' },
  { name: 'Accident & Incident Report Form + Log', desc: 'RIDDOR-aligned reporting form and running log with dedicated Animal Involved section — capturing breed, temperament, vaccination status, and incident details. Ready to print and keep on site.' },
  { name: 'Quick-Start Compliance Guide', desc: 'Step-by-step guide to get audit-ready in 60 minutes. References the Animal Welfare Act 2006, includes RSPCA/ISPCA contacts, and tells you exactly what to do with each document and in what order.' },
];

const proDocs = [
  { name: 'Fire Risk Assessment', desc: 'Five-step fire risk assessment covering mobile van LPG/generator risks, dog hair accumulation as fire fuel, ignition sources, fire detection, escape routes, and animal evacuation procedures.' },
  { name: 'Staff Induction Checklist', desc: 'Structured checklist with 12 sections ensuring every new employee is properly inducted — including animal behaviour awareness, noise exposure protocols, and grooming-specific H&S procedures from day one.' },
  { name: 'Training Presentation (26 Slides)', desc: 'Ready-to-deliver staff training covering hazard awareness, COSHH basics, manual handling, emergency procedures, dog body language and stress signals recognition, and reporting. Includes speaker notes.' },
  { name: 'Staff Knowledge Quiz (20 Questions)', desc: 'Multiple-choice assessment with answer key covering grooming-specific hazards — including permethrin cat toxicity awareness. Proves staff have understood their training for due diligence.' },
  { name: 'Training Record Log & Matrix', desc: 'Track who has been trained, when, and on what. Includes canine behaviour certification tracker. Demonstrates ongoing compliance to inspectors and clients.' },
  { name: 'Annual H&S Review Checklist', desc: 'Structured annual review covering all compliance areas including a dedicated animal welfare section. Ensures nothing slips through the cracks year to year.' },
  { name: 'PPE Assessment', desc: 'Assessment of PPE requirements for all grooming tasks — Kevlar bite-resistant gloves, hearing protection for high-velocity dryers, waterproof aprons, eye protection. Includes EN standards for each item.' },
  { name: 'Client Site Assessment', desc: 'Pre-work assessment template for new clients. Captures essential dog information — breed, temperament, vaccination status, and aggression history — before grooming begins.' },
  { name: 'Emergency Procedures', desc: 'Comprehensive emergency procedures covering 10 incident types — including grooming noose strangulation, dog escape from premises, animal evacuation, chemical spills, and first aid. Wall-display-ready.' },
  { name: 'Ireland Safety Statement', desc: 'Full safety statement compliant with the Safety, Health and Welfare at Work Act 2005 and the Animal Health and Welfare Act 2013. Required for all Irish businesses.' },
];

const chemicals = [
  'Dog Shampoo (General)',
  'Medicated / Flea Shampoo (Permethrin)',
  'Ear Cleaning Solution',
  'Styptic Powder / Blood Stop',
  'Kennel / Cage Disinfectant',
  'Clipper Blade Wash / Coolant',
  'De-matting Spray / Coat Conditioner',
  'Hand Sanitiser / Antibacterial Wash',
];

const faqs = [
  {
    q: 'Are these just blank templates?',
    a: 'No. Every document is pre-filled with real dog grooming content — 8 chemicals with H-codes and GHS data, 13 operational risk assessments, breed-specific handling notes, zoonotic disease protocols, and real control measures. You just add your company name and review.',
  },
  {
    q: 'Do I need the Basic or Pro kit?',
    a: 'If you\'re a sole trader working alone, the Basic kit covers everything you legally need. If you employ staff (even one person), the Pro kit adds training materials including dog body language recognition slides, induction checklists, and ongoing compliance tools that demonstrate due diligence.',
  },
  {
    q: 'Is this compliant with UK and Irish law?',
    a: 'Yes. All documents align with the Health and Safety at Work Act 1974, Management of Health and Safety at Work Regulations 1999, COSHH Regulations 2002, Noise at Work Regulations 2005, PUWER 1998, and the Animal Welfare Act 2006 (UK). The Pro kit includes an Ireland Safety Statement compliant with the SHWW Act 2005 and the Animal Health and Welfare Act 2013.',
  },
  {
    q: 'What format are the documents?',
    a: 'The Basic kit includes print-ready PDFs. The Pro kit includes both PDFs and editable Word (.docx) files so you can customise everything to your business.',
  },
  {
    q: 'Can I buy individual documents instead?',
    a: 'Yes. Individual risk assessments and COSHH assessments are available from \u00a312 each. But the full kit is much better value — 19 documents for \u00a379 works out at just \u00a34.16 each.',
  },
  {
    q: 'What if regulations change?',
    a: 'All documents include version dates. We monitor UK and Irish regulatory changes and offer free updates to kit buyers when significant changes occur.',
  },
  {
    q: 'Do I get a refund if it\'s not what I expected?',
    a: 'As a digital download, all sales are final once the file is downloaded. That\'s why we offer a free sample — download it first to check the quality and format before purchasing.',
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://healthandsafetykits.com" },
    { "@type": "ListItem", "position": 2, "name": "Kits", "item": "https://healthandsafetykits.com/kits/" },
    { "@type": "ListItem", "position": 3, "name": "Dog Grooming Business Kit", "item": "https://healthandsafetykits.com/kits/dog-grooming/" },
  ],
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Dog Grooming Business H&S Compliance Kit",
  "description": "Complete health and safety compliance kit for dog grooming businesses. 19 pre-filled documents including risk assessments, COSHH assessments for 8 chemicals, policies, and training materials.",
  "brand": { "@type": "Brand", "name": "Health and Safety Kits" },
  "image": "https://healthandsafetykits.com/images/healthandsafetykits-og.png",
  "offers": [
    {
      "@type": "Offer",
      "name": "Basic Kit",
      "price": "49.00",
      "priceCurrency": "GBP",
      "availability": "https://schema.org/InStock",
      "url": "https://healthandsafetykits.com/kits/dog-grooming/",
    },
    {
      "@type": "Offer",
      "name": "Pro Kit",
      "price": "79.00",
      "priceCurrency": "GBP",
      "availability": "https://schema.org/InStock",
      "url": "https://healthandsafetykits.com/kits/dog-grooming/",
    },
  ],
};
---

<BaseLayout
  title="Dog Grooming Business H&S Kit"
  description="Complete health and safety kit for dog grooming businesses. 19 pre-filled documents — risk assessments, COSHH assessments for 8 chemicals, H&S policy, training materials. From £49. One-time download."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} slot="head" />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/kits/">Kits</a>
        <span aria-hidden="true">/</span>
        <span>Dog Grooming Business</span>
      </nav>
      <h1>Dog Grooming Business H&amp;S Compliance Kit</h1>
      <p class="hero-subtitle">
        19 professional compliance documents &mdash; pre-filled with real grooming hazards,
        8 chemicals used in dog care, breed-specific handling protocols, and zoonotic disease procedures.
        <strong>Audit-ready in 60 minutes.</strong>
      </p>
      <div class="hero-pricing">
        <div class="price-option">
          <span class="price-label">Basic Kit</span>
          <span class="price-amount">&pound;49</span>
          <span class="price-detail">9 documents &middot; PDFs</span>
        </div>
        <div class="price-divider"></div>
        <div class="price-option price-option-featured">
          <span class="price-badge">Most Popular</span>
          <span class="price-label">Pro Kit</span>
          <span class="price-amount">&pound;79</span>
          <span class="price-detail">19 documents &middot; PDFs + Word</span>
        </div>
      </div>
      <div class="hero-cta">
        <a href="#buy" class="btn btn-primary btn-lg">Buy Now</a>
        <a href="/free-sample/" class="btn btn-secondary btn-lg">Try Free Sample First</a>
      </div>
      <p class="hero-note">One-time purchase. Instant download. No subscriptions.</p>
    </div>
  </section>

  <!-- Who This Is For -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Built for Dog Grooming Business Owners Like You</h2>
      <div class="audience-grid">
        <div class="audience-card">
          <h3>Sole Trader Groomers</h3>
          <p>Working from a home salon or mobile van. Need H&amp;S docs for insurance, local authority licensing, or client confidence.</p>
        </div>
        <div class="audience-card">
          <h3>Dog Grooming Salons</h3>
          <p>Small premises employing 1&ndash;5 groomers. Clients and insurers expect documented safety procedures for animal and staff welfare.</p>
        </div>
        <div class="audience-card">
          <h3>Mobile Grooming Van Operators</h3>
          <p>Unique risks from confined spaces, gas/electric supply, and travelling between clients. Documents cover both salon and mobile operations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included: Basic -->
  <section class="section included-section" id="whats-included">
    <div class="container">
      <h2 class="text-center">What&rsquo;s in the Kit</h2>
      <p class="section-subtitle">
        Every document is pre-filled with dog-grooming-specific content.
        Real hazards, real chemicals, real control measures.
      </p>

      <h3 class="tier-heading">Basic Kit &mdash; &pound;49 <span class="tier-count">(9 documents)</span></h3>
      <div class="docs-grid">
        {basicDocs.map((doc) => (
          <div class="doc-card">
            <h4>{doc.name}</h4>
            <p>{doc.desc}</p>
          </div>
        ))}
      </div>

      <h3 class="tier-heading tier-heading-pro">Pro Kit Adds &mdash; &pound;79 total <span class="tier-count">(all 19 documents)</span></h3>
      <p class="tier-note">Everything in Basic, plus these 10 additional documents:</p>
      <div class="docs-grid">
        {proDocs.map((doc) => (
          <div class="doc-card doc-card-pro">
            <h4>{doc.name}</h4>
            <p>{doc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COSHH Chemicals Covered -->
  <section class="section chemicals-section">
    <div class="container">
      <h2 class="text-center">COSHH Assessments for 8 Dog Grooming Chemicals</h2>
      <p class="section-subtitle">
        Each chemical has its own individual COSHH assessment with real H-codes,
        GHS hazard classifications, exposure routes, control measures, PPE requirements,
        first aid procedures, and emergency spill response.
      </p>
      <div class="chemicals-grid">
        {chemicals.map((chem) => (
          <div class="chemical-card">
            <span class="chemical-icon">&#9878;</span>
            <span>{chem}</span>
          </div>
        ))}
      </div>
      <p class="text-center" style="margin-top: 1.5rem; color: #4b5563; font-size: 0.9rem;">
        Not using these exact products? The editable Word versions in the Pro kit let you swap in your specific chemicals.
      </p>
    </div>
  </section>

  <!-- Value Comparison -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">How This Compares</h2>
      <div class="comparison-table">
        <table>
          <thead>
            <tr>
              <th></th>
              <th>H&amp;S Consultant</th>
              <th>HASpod (a la carte)</th>
              <th class="highlight-col">Our Dog Grooming Kit</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Cost</td>
              <td>&pound;500&ndash;&pound;2,000+</td>
              <td>&pound;85&ndash;&pound;100+ (for equivalent docs)</td>
              <td class="highlight-col"><strong>&pound;49&ndash;&pound;79</strong></td>
            </tr>
            <tr>
              <td>Dog grooming-specific content</td>
              <td>Sometimes</td>
              <td>No (generic templates)</td>
              <td class="highlight-col"><strong>Yes &mdash; 8 chemicals, 13 hazards, breed handling, zoonotic diseases</strong></td>
            </tr>
            <tr>
              <td>Pre-filled documents</td>
              <td>Yes</td>
              <td>No</td>
              <td class="highlight-col"><strong>Yes</strong></td>
            </tr>
            <tr>
              <td>Training materials</td>
              <td>Sometimes</td>
              <td>No</td>
              <td class="highlight-col"><strong>Yes (Pro kit)</strong></td>
            </tr>
            <tr>
              <td>Ireland Safety Statement</td>
              <td>Rarely</td>
              <td>No</td>
              <td class="highlight-col"><strong>Yes (Pro kit)</strong></td>
            </tr>
            <tr>
              <td>Ongoing fees</td>
              <td>Per visit</td>
              <td>&pound;799/year for full access</td>
              <td class="highlight-col"><strong>Never &mdash; one-time purchase</strong></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing / Buy Section -->
  <section class="section pricing-section" id="buy">
    <div class="container">
      <h2 class="text-center">Choose Your Kit</h2>
      <p class="section-subtitle">
        Both tiers include the same professional, pre-filled dog-grooming documents.
        Pro adds training, ongoing compliance tools, and editable Word files.
      </p>
      <div class="pricing-grid">
        <div class="pricing-card">
          <h3>Basic Kit</h3>
          <div class="pricing-amount">&pound;49</div>
          <p class="pricing-detail">9 documents &middot; Print-ready PDFs</p>
          <ul class="pricing-list">
            <li>H&amp;S Policy (pre-filled)</li>
            <li>General Risk Assessment</li>
            <li>Dog Grooming Operations Risk Assessment</li>
            <li>COSHH Assessments (8 chemicals)</li>
            <li>Manual Handling Assessment</li>
            <li>Lone Working Policy</li>
            <li>Slip, Trip &amp; Fall Assessment</li>
            <li>Accident Report Form + Log</li>
            <li>Quick-Start Compliance Guide</li>
          </ul>
          <a href="#" class="btn btn-secondary btn-block">Buy Basic Kit &mdash; &pound;49</a>
          <p class="pricing-note">&pound;5.44 per document</p>
        </div>
        <div class="pricing-card pricing-card-featured">
          <span class="pricing-badge">Most Popular</span>
          <h3>Pro Kit</h3>
          <div class="pricing-amount">&pound;79</div>
          <p class="pricing-detail">19 documents &middot; PDFs + Editable Word</p>
          <ul class="pricing-list">
            <li>Everything in Basic, plus:</li>
            <li>Fire Risk Assessment</li>
            <li>Staff Induction Checklist</li>
            <li>Training Presentation (26 slides)</li>
            <li>Staff Knowledge Quiz (20 Qs)</li>
            <li>Training Record Log &amp; Matrix</li>
            <li>Annual H&amp;S Review Checklist</li>
            <li>PPE Assessment (Kevlar bite gloves)</li>
            <li>Client Site Assessment</li>
            <li>Emergency Procedures (10 types)</li>
            <li>Ireland Safety Statement</li>
          </ul>
          <a href="#" class="btn btn-primary btn-block">Buy Pro Kit &mdash; &pound;79</a>
          <p class="pricing-note">&pound;4.16 per document</p>
        </div>
      </div>
      <p class="text-center" style="margin-top: 1.5rem; color: #6b7280; font-size: 0.9rem;">
        Secure payment via Gumroad. Instant download. Free sample available to try first.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container" style="max-width: 780px;">
      <h2 class="text-center">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section cta-section">
    <div class="container text-center">
      <h2>Get Your Grooming Business Compliant Today</h2>
      <p>19 professional documents. Pre-filled for dog grooming businesses. Audit-ready in 60 minutes.</p>
      <div class="cta-buttons">
        <a href="#buy" class="btn btn-primary btn-lg">Buy Dog Grooming Kit &mdash; From &pound;49</a>
        <a href="/free-sample/" class="btn btn-ghost btn-lg">Try Free Sample First</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(135deg, #eff6ff, #dbeafe);
    padding: 2rem 0 3.5rem;
    text-align: center;
  }

  .breadcrumbs {
    font-size: 0.825rem;
    color: #6b7280;
    margin-bottom: 1.5rem;
  }

  .breadcrumbs a {
    color: #6b7280;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: #2563eb;
    text-decoration: underline;
  }

  .breadcrumbs span[aria-hidden] {
    margin: 0 0.4rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: #4b5563;
    max-width: 650px;
    margin: 0 auto 2rem;
    line-height: 1.65;
  }

  .hero-pricing {
    display: flex;
    gap: 2rem;
    justify-content: center;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .price-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    position: relative;
  }

  .price-option-featured {
    background: #fff;
    border: 2px solid #2563eb;
    border-radius: 0.75rem;
    padding: 1rem 2rem;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  }

  .price-badge {
    position: absolute;
    top: -0.65rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: #2563eb;
    color: #fff;
    padding: 0.15rem 0.6rem;
    border-radius: 9999px;
  }

  .price-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #4b5563;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .price-amount {
    font-size: 2.25rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .price-detail {
    font-size: 0.8rem;
    color: #6b7280;
  }

  .price-divider {
    width: 1px;
    height: 3rem;
    background: #d1d5db;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .hero-note {
    font-size: 0.85rem;
    color: #6b7280;
    margin-bottom: 0;
  }

  .btn-lg {
    padding: 0.875rem 2rem;
    font-size: 1.05rem;
  }

  .btn-ghost {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #fff;
    text-decoration: none;
  }

  .btn-block {
    display: block;
    width: 100%;
    text-align: center;
  }

  /* Section subtitle */
  .section-subtitle {
    max-width: 650px;
    margin: 0 auto 2.5rem;
    text-align: center;
    color: #4b5563;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  /* Audience grid */
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .audience-card {
    padding: 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    background: #fff;
  }

  .audience-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }

  .audience-card p {
    color: #4b5563;
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 0;
  }

  /* Documents included */
  .included-section {
    background: #f9fafb;
  }

  .tier-heading {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #2563eb;
  }

  .tier-heading-pro {
    margin-top: 3rem;
    border-color: #7c3aed;
  }

  .tier-count {
    font-size: 0.9rem;
    font-weight: 400;
    color: #6b7280;
  }

  .tier-note {
    color: #4b5563;
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .doc-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 1.25rem;
  }

  .doc-card-pro {
    border-left: 3px solid #7c3aed;
  }

  .doc-card h4 {
    font-size: 0.975rem;
    margin-bottom: 0.35rem;
    color: #1a1a1a;
  }

  .doc-card p {
    font-size: 0.85rem;
    color: #4b5563;
    line-height: 1.5;
    margin-bottom: 0;
  }

  /* Chemicals */
  .chemicals-section {
    background: #fff;
  }

  .chemicals-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .chemical-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border: 1px solid #fde68a;
    border-radius: 0.5rem;
    background: #fffbeb;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .chemical-icon {
    font-size: 1.1rem;
  }

  /* Comparison table */
  .comparison-table {
    max-width: 850px;
    margin: 0 auto;
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th, td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
    font-size: 0.9rem;
  }

  th {
    font-weight: 600;
    background: #f9fafb;
    font-size: 0.85rem;
  }

  .highlight-col {
    background: #eff6ff;
  }

  /* Pricing */
  .pricing-section {
    background: #f9fafb;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .pricing-card {

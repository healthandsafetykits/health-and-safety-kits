---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const tags = [...new Set(posts.flatMap(p => p.data.tags))];
  return tags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter(p => p.data.tags.includes(tag))
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
      allTags: tags,
    },
  }));
}

const { tag, posts, allTags } = Astro.props;

// Tag metadata
const tagMeta: Record<string, { title: string; description: string }> = {
  'risk-assessment': {
    title: 'Risk Assessment Guides | Health and Safety Kits',
    description: 'Step-by-step guides on conducting workplace risk assessments for UK and Ireland small businesses.',
  },
  'compliance': {
    title: 'H&S Compliance Guides | Health and Safety Kits',
    description: 'Understand your health and safety legal obligations under UK and Ireland law.',
  },
  'coshh': {
    title: 'COSHH Assessment Guides | Health and Safety Kits',
    description: 'Guides on COSHH assessments and controlling hazardous substances in your workplace.',
  },
  'policy': {
    title: 'Health and Safety Policy Guides | Health and Safety Kits',
    description: 'How to write and maintain health and safety policy documents for your business.',
  },
  'fire-safety': {
    title: 'Fire Safety Guides | Health and Safety Kits',
    description: 'Fire risk assessment guides and fire safety compliance for businesses.',
  },
  'construction': {
    title: 'Construction H&S Guides | Health and Safety Kits',
    description: 'Health and safety guides for construction, CDM 2015, and trades.',
  },
  'method-statement': {
    title: 'Method Statement Guides | Health and Safety Kits',
    description: 'How to write method statements and RAMS for safe systems of work.',
  },
  'training': {
    title: 'H&S Training Guides | Health and Safety Kits',
    description: 'Staff training and competence guides for health and safety compliance.',
  },
  'cleaning': {
    title: 'Cleaning Business H&S Guides | Health and Safety Kits',
    description: 'Health and safety guides specifically for cleaning businesses and facilities management.',
  },
  'landscaping': {
    title: 'Landscaping H&S Guides | Health and Safety Kits',
    description: 'Health and safety guides for landscaping, grounds maintenance, and gardening businesses.',
  },
  'beauty': {
    title: 'Beauty Salon H&S Guides | Health and Safety Kits',
    description: 'Health and safety guides for beauty salons, mobile beauticians, and hairdressers.',
  },
  'dog-grooming': {
    title: 'Dog Grooming H&S Guides | Health and Safety Kits',
    description: 'Health and safety guides for dog groomers, pet care, and animal handling businesses.',
  },
  'small-business': {
    title: 'Small Business H&S Guides | Health and Safety Kits',
    description: 'Health and safety compliance guides for UK and Ireland sole traders and micro businesses.',
  },
};

const meta = tagMeta[tag] || {
  title: `${tag.charAt(0).toUpperCase() + tag.slice(1).replace(/-/g, ' ')} | Health and Safety Kits`,
  description: `Health and safety guides about ${tag.replace(/-/g, ' ')} for UK and Ireland small businesses.`,
};

// Thin content protection: noindex if fewer than 2 posts
const robots = posts.length < 2 ? 'noindex,follow' : 'index,follow';

// Helper
function getReadingTime(body: string | undefined): number {
  if (!body) return 1;
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 230));
}

const tagLabel = tag.charAt(0).toUpperCase() + tag.slice(1).replace(/-/g, ' ');
const otherTags = allTags.filter((t: string) => t !== tag);
---

<BaseLayout title={meta.title.split(' | ')[0]} description={meta.description} robots={robots}>

  <section class="section">
    <div class="container" style="max-width: 800px;">

      <!-- Breadcrumbs -->
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/blog/">Blog</a>
        <span aria-hidden="true">/</span>
        <span>{tagLabel}</span>
      </nav>

      <header class="tag-header">
        <h1>{tagLabel}</h1>
        <p>{meta.description}</p>
        <p class="post-count">{posts.length} {posts.length === 1 ? 'article' : 'articles'}</p>
      </header>

      <!-- Posts -->
      <div class="posts-list">
        {posts.map((post: any) => (
          <a href={`/blog/${post.id}/`} class="post-card">
            <div class="post-card-meta">
              <time datetime={new Date(post.data.date).toISOString()}>
                {new Date(post.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
              </time>
              <span>{getReadingTime(post.body)} min read</span>
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <div class="post-card-tags">
              {post.data.tags.map((t: string) => (
                <span class:list={['tag-sm', { active: t === tag }]}>{t.replace(/-/g, ' ')}</span>
              ))}
            </div>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <aside class="tag-cta">
        <h3>Get Your Free H&amp;S Compliance Sample</h3>
        <p>Download a sample risk assessment and COSHH assessment &mdash; free, no signup.</p>
        <div class="cta-buttons">
          <a href="/free-sample/" class="btn btn-primary">Download Free Sample</a>
          <a href="/kits/" class="btn btn-secondary">Compare All Kits</a>
        </div>
      </aside>

      <!-- Related tags -->
      {otherTags.length > 0 && (
        <nav class="related-tags" aria-label="Related topics">
          <h3>Explore Other Topics</h3>
          <div class="tags-row">
            {otherTags.map((t: string) => (
              <a href={`/tags/${t}/`} class="tag-pill">
                {t.charAt(0).toUpperCase() + t.slice(1).replace(/-/g, ' ')}
              </a>
            ))}
          </div>
        </nav>
      )}

    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumbs {
    font-size: 0.825rem;
    color: #6b7280;
    margin-bottom: 2rem;
  }

  .breadcrumbs a {
    color: #6b7280;
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    color: #2563eb;
    text-decoration: underline;
  }

  .breadcrumbs span[aria-hidden] {
    margin: 0 0.4rem;
  }

  .tag-header {
    margin-bottom: 2rem;
  }

  .tag-header h1 {
    margin-bottom: 0.5rem;
  }

  .tag-header p {
    color: #4b5563;
  }

  .post-count {
    font-size: 0.85rem;
    color: #9ca3af !important;
    margin-top: 0.25rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .post-card:hover {
    border-color: #2563eb;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.08);
    text-decoration: none;
  }

  .post-card-meta {
    display: flex;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: #9ca3af;
    margin-bottom: 0.4rem;
  }

  .post-card h3 {
    font-size: 1.15rem;
    color: #1a1a1a;
    margin-bottom: 0.3rem;
  }

  .post-card p {
    font-size: 0.9rem;
    color: #4b5563;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .post-card-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .tag-sm {
    font-size: 0.7rem;
    padding: 0.1rem 0.45rem;
    background: #f3f4f6;
    color: #6b7280;
    border-radius: 9999px;
  }

  .tag-sm.active {
    background: #dbeafe;
    color: #2563eb;
  }

  .tag-cta {
    margin-top: 2.5rem;
    padding: 2rem;
    background: linear-gradient(135deg, #eff6ff 0%, #ecfdf5 100%);
    border-radius: 0.75rem;
    text-align: center;
  }

  .tag-cta h3 {
    margin-bottom: 0.5rem;
  }

  .tag-cta p {
    color: #4b5563;
    margin-bottom: 1.25rem;
  }

  .cta-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .related-tags {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
  }

  .related-tags h3 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }

  .tags-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag-pill {
    padding: 0.3rem 0.75rem;
    background: #f3f4f6;
    color: #374151;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s;
  }

  .tag-pill:hover {
    background: #dbeafe;
    color: #2563eb;
    text-decoration: none;
  }
</style>

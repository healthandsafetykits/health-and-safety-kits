---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = 'https://healthandsafetykits.com';
const priceValidUntil = `${new Date().getFullYear() + 1}-12-31`;

const homeFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need health and safety experience to use these kits?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No — all documents are written in plain English for non-specialists. Every template is pre-filled with trade-specific content. Just add your company name and review."
      }
    },
    {
      "@type": "Question",
      "name": "Is this a subscription?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. All kits are a one-time download. No subscriptions, no logins, no recurring fees. You buy once and use forever."
      }
    },
    {
      "@type": "Question",
      "name": "Can I see a sample before buying?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — download the free sample kit first, no email or signup required. It includes a real Risk Assessment and COSHH Assessment from our Cleaning Business Kit."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl }
  ]
};
---

<BaseLayout title="Home" description="Trade-specific H&S kits for UK & Ireland small businesses. Risk assessments, COSHH, policies & training — audit-ready in 60 minutes. From £49.">
  <script type="application/ld+json" set:html={JSON.stringify(homeFaqSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">For Sole Traders &amp; Small Businesses in the UK &amp; Ireland</p>
      <h1>Get H&amp;S Compliant in 60 Minutes.<br />Not 60 Days.</h1>
      <p class="hero-subtitle">
        Trade-specific health &amp; safety documents &mdash; pre-filled with real hazards,
        real chemicals, and real control measures for <em>your</em> trade.
        Just add your company name and print.
      </p>
      <div class="hero-cta">
        <a href="/kits/" class="btn btn-primary btn-lg">View All Kits &mdash; From &pound;49</a>
        <a href="/free-sample/" class="btn btn-secondary btn-lg">Try Free Sample</a>
      </div>
      <p class="hero-note">One-time download. No subscriptions. No logins. Yours forever.</p>
    </div>
  </section>

  <!-- Problem / Pain Points -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Sound Familiar?</h2>
      <div class="pain-grid">
        <div class="pain-card">
          <h3>Won a Contract &mdash; But They Want H&amp;S Docs</h3>
          <p>You&rsquo;ve been asked for a health and safety policy, risk assessments, or COSHH assessments before you can start. You don&rsquo;t know where to begin.</p>
        </div>
        <div class="pain-card">
          <h3>Free Templates Are Useless</h3>
          <p>The HSE templates are blank forms designed for offices and factories. They don&rsquo;t mention your chemicals, your hazards, or your way of working.</p>
        </div>
        <div class="pain-card">
          <h3>Consultants Want &pound;500+</h3>
          <p>You only need the basics &mdash; not a &pound;2,000 audit. But everything out there is either too expensive or too generic.</p>
        </div>
        <div class="pain-card">
          <h3>SaaS Platforms Charge &pound;799/Year</h3>
          <p>Subscription services give you 790 templates when you need 9. And you&rsquo;re paying every year for documents you download once.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution -->
  <section class="section solution-section">
    <div class="container">
      <h2 class="text-center">We Built the Kit You Actually Need</h2>
      <p class="section-subtitle">
        Every document is <strong>pre-filled</strong> for your specific trade &mdash; not blank templates
        you have to figure out yourself. Real hazards. Real chemicals with safety data.
        Real control measures already written.
      </p>
      <div class="features-grid">
        <div class="feature">
          <span class="feature-icon">&#10003;</span>
          <div>
            <h3>Trade-Specific, Not Generic</h3>
            <p>Your kit covers the exact hazards, chemicals, and risks for your trade. Not a one-size-fits-all template pack.</p>
          </div>
        </div>
        <div class="feature">
          <span class="feature-icon">&#10003;</span>
          <div>
            <h3>Pre-Filled &amp; Ready to Use</h3>
            <p>COSHH assessments with real H-codes and GHS data. Risk assessments with real control measures. Just add your business name.</p>
          </div>
        </div>
        <div class="feature">
          <span class="feature-icon">&#10003;</span>
          <div>
            <h3>UK &amp; Ireland Compliant</h3>
            <p>Aligned with the Health and Safety at Work Act 1974, MHSWR 1999, COSHH 2002, and the Irish SHWW Act 2005.</p>
          </div>
        </div>
        <div class="feature">
          <span class="feature-icon">&#10003;</span>
          <div>
            <h3>One-Time Purchase</h3>
            <p>Pay once, download instantly, use forever. No subscriptions, no logins, no per-user fees. It&rsquo;s yours.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Price Comparison / Anchoring -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">How We Compare</h2>
      <p class="section-subtitle">
        You need H&amp;S documents. Here are your options:
      </p>
      <div class="comparison-table">
        <table>
          <thead>
            <tr>
              <th>Option</th>
              <th>Cost</th>
              <th>Trade-Specific?</th>
              <th>Pre-Filled?</th>
              <th>Ongoing Fees?</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>H&amp;S Consultant</td>
              <td>&pound;500&ndash;&pound;2,000+</td>
              <td>Sometimes</td>
              <td>Yes</td>
              <td>Per visit</td>
            </tr>
            <tr>
              <td>SaaS Platform (e.g. HASpod)</td>
              <td>&pound;799/year</td>
              <td>Construction only</td>
              <td>No</td>
              <td><strong>&pound;799 every year</strong></td>
            </tr>
            <tr>
              <td>HSE.gov.uk Templates</td>
              <td>Free</td>
              <td>No</td>
              <td>No</td>
              <td>N/A</td>
            </tr>
            <tr class="highlight-row">
              <td><strong>Health and Safety Kits</strong></td>
              <td><strong>&pound;49&ndash;&pound;79</strong></td>
              <td><strong>Yes</strong></td>
              <td><strong>Yes</strong></td>
              <td><strong>Never</strong></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section how-it-works">
    <div class="container">
      <h2 class="text-center">Audit-Ready in 4 Steps</h2>
      <div class="steps-grid">
        <div class="step">
          <span class="step-number">1</span>
          <h3>Choose Your Trade</h3>
          <p>Pick the kit that matches your business &mdash; cleaning, landscaping, beauty, dog grooming, and more.</p>
        </div>
        <div class="step">
          <span class="step-number">2</span>
          <h3>Download Instantly</h3>
          <p>Pay once via secure checkout. Your ZIP file downloads immediately &mdash; PDFs and editable Word documents.</p>
        </div>
        <div class="step">
          <span class="step-number">3</span>
          <h3>Add Your Details</h3>
          <p>Documents come pre-filled with real hazards and controls. Just add your company name, address, and review.</p>
        </div>
        <div class="step">
          <span class="step-number">4</span>
          <h3>You&rsquo;re Compliant</h3>
          <p>Print or save as PDF. Show clients, insurers, and inspectors you take health &amp; safety seriously.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Available Kits -->
  <section class="section kits-overview">
    <div class="container">
      <h2 class="text-center">Trade-Specific Kits</h2>
      <p class="section-subtitle">
        Each kit is built for a specific trade. Not a generic pack &mdash; real documents
        with real content for your business.
      </p>
      <div class="kits-grid">
        <div class="kit-card kit-card-featured">
          <span class="kit-badge">Available Now</span>
          <h3>Cleaning Business</h3>
          <p>19 documents including COSHH assessments for 8 chemicals, cleaning operations risk assessment, lone working, manual handling, slips &amp; trips, fire safety, staff training, and more.</p>
          <div class="kit-price">From <strong>&pound;49</strong></div>
          <a href="/kits/cleaning/" class="btn btn-primary">View Cleaning Kit</a>
        </div>
        <div class="kit-card kit-card-featured">
          <span class="kit-badge">Available Now</span>
          <h3>Landscaping &amp; Grounds</h3>
          <p>19 documents including COSHH for 8 pesticides and herbicides, equipment risk assessments, work at height, noise &amp; vibration, chainsaw safety, manual handling, and more.</p>
          <div class="kit-price">From <strong>&pound;49</strong></div>
          <a href="/kits/landscaping/" class="btn btn-primary">View Landscaping Kit</a>
        </div>
        <div class="kit-card kit-card-featured">
          <span class="kit-badge">Available Now</span>
          <h3>Beauty Salon &amp; Hair</h3>
          <p>19 documents including COSHH for 8 salon chemicals, beauty operations risk assessment, infection control, client safety, patch testing protocols, and more.</p>
          <div class="kit-price">From <strong>&pound;49</strong></div>
          <a href="/kits/beauty/" class="btn btn-primary">View Beauty Kit</a>
        </div>
        <div class="kit-card kit-card-featured">
          <span class="kit-badge">Available Now</span>
          <h3>Dog Grooming &amp; Pets</h3>
          <p>19 documents including COSHH for 8 grooming chemicals, animal handling &amp; bite risk, zoonotic disease protocols, noise exposure, equipment safety, and more.</p>
          <div class="kit-price">From <strong>&pound;49</strong></div>
          <a href="/kits/dog-grooming/" class="btn btn-primary">View Dog Grooming Kit</a>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section whats-included-section">
    <div class="container">
      <h2 class="text-center">What&rsquo;s Inside Every Kit?</h2>
      <p class="section-subtitle">
        Each kit contains 19 professional documents &mdash; all pre-filled for your trade.
        Basic (9 docs, &pound;49) or Pro (19 docs, &pound;79).
      </p>
      <div class="included-grid">
        <div class="included-card">
          <h3>Risk Assessments</h3>
          <p>General, trade-specific, manual handling, slips/trips, fire &mdash; pre-filled with real hazards and control measures.</p>
        </div>
        <div class="included-card">
          <h3>COSHH Assessments</h3>
          <p>Chemical-by-chemical assessments with real H-codes, GHS data, and control measures for 8 trade-specific substances.</p>
        </div>
        <div class="included-card">
          <h3>Policies &amp; Training</h3>
          <p>H&amp;S policy, lone working policy, training presentation, staff quiz, induction checklist, and more.</p>
        </div>
      </div>
      <p class="text-center" style="margin-top: 1.5rem; color: #4b5563;">
        <a href="/kits/">Compare Basic vs Pro kits for your trade</a>.
      </p>
    </div>
  </section>

  <!-- Trust / Compliance -->
  <section class="section trust-section">
    <div class="container">
      <h2 class="text-center">Built for Compliance</h2>
      <div class="trust-grid">
        <div class="trust-item">
          <h3>UK Regulation Aligned</h3>
          <p>Health and Safety at Work Act 1974, Management of H&amp;S at Work Regulations 1999, COSHH Regulations 2002</p>
        </div>
        <div class="trust-item">
          <h3>Ireland Compliant</h3>
          <p>Safety, Health and Welfare at Work Act 2005. Pro kits include a dedicated Ireland Safety Statement.</p>
        </div>
        <div class="trust-item">
          <h3>Written by Compliance Experts</h3>
          <p>20+ years of IT and compliance experience. Same team behind SMBCyberHub&rsquo;s cybersecurity compliance kits.</p>
        </div>
        <div class="trust-item">
          <h3>Instant, Secure Download</h3>
          <p>Secure payment via Gumroad. Instant ZIP download with PDFs and editable Word files. No account needed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Guides -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Popular Compliance Guides</h2>
      <p class="section-subtitle">
        Free, in-depth guides to help you understand your health &amp; safety obligations.
      </p>
      <div class="guides-grid">
        <a href="/blog/health-and-safety-for-cleaning-businesses/" class="guide-card">
          <h3>H&amp;S for Cleaning Businesses</h3>
          <p>Complete compliance guide for cleaning companies and sole traders.</p>
        </a>
        <a href="/blog/health-and-safety-risk-assessment-guide/" class="guide-card">
          <h3>Risk Assessment Guide</h3>
          <p>Step-by-step guide to the HSE 5-step risk assessment process.</p>
        </a>
        <a href="/blog/coshh-assessment-guide/" class="guide-card">
          <h3>COSHH Assessment Guide</h3>
          <p>How to assess hazardous substances in your workplace.</p>
        </a>
        <a href="/blog/do-i-need-health-and-safety-policy-sole-trader/" class="guide-card">
          <h3>Do Sole Traders Need a H&amp;S Policy?</h3>
          <p>Legal requirements and what clients and insurers expect.</p>
        </a>
      </div>
      <p class="text-center" style="margin-top: 1.5rem;">
        <a href="/blog/" class="btn btn-secondary">View All Guides</a>
      </p>
    </div>
  </section>

  <!-- Free Sample CTA -->
  <section class="section">
    <div class="container text-center">
      <div class="sample-cta-box">
        <h2>Not Sure Yet? Try Before You Buy</h2>
        <p>Download a free sample with a Risk Assessment and COSHH Assessment. No email required &mdash; just download and see the quality for yourself.</p>
        <a href="/free-sample/" class="btn btn-secondary btn-lg">Download Free Sample</a>
      </div>
    </div>
  </section>

  <!-- TL;DR AI Answer Box -->
  <section class="section">
    <div class="container">
      <div class="tldr-box">
        <h3 class="tldr-title">TL;DR: Trade-Specific H&amp;S Compliance in 60 Minutes</h3>
        <div class="tldr-grid">
          <div>
            <h4>What It Is</h4>
            <ul>
              <li>Downloadable compliance kits</li>
              <li>Pre-filled risk assessments</li>
              <li>COSHH assessments with real chemical data</li>
              <li>H&amp;S policies &amp; training materials</li>
            </ul>
          </div>
          <div>
            <h4>Key Benefits</h4>
            <ul>
              <li>Audit-ready in 60 minutes</li>
              <li>UK &amp; Ireland regulation aligned</li>
              <li>HSWA 1974 &amp; COSHH 2002 compliant</li>
              <li>No subscriptions ever</li>
            </ul>
          </div>
          <div>
            <h4>Perfect For</h4>
            <ul>
              <li>Sole traders &amp; micro businesses (1&ndash;5 staff)</li>
              <li>Cleaning, landscaping, beauty, dog grooming</li>
              <li>No H&amp;S experience needed</li>
              <li>Contract &amp; insurance compliance</li>
            </ul>
          </div>
        </div>
        <p class="tldr-pricing"><strong>Pricing:</strong> Free sample available &middot; Basic Kit &pound;49 &middot; Pro Kit &pound;79 &middot; One-time purchase &middot; Instant download</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section testimonials-section">
    <div class="container">
      <h2 class="text-center">What Our Customers Say</h2>
      <div class="testimonials-grid">
        <blockquote class="testimonial-card">
          <p>&ldquo;Got asked for H&amp;S docs by a new client on Friday. Bought the cleaning kit, printed everything Monday morning. Honestly thought it would take ages but it was pretty much done.&rdquo;</p>
          <cite>&mdash; S.M., Birmingham</cite>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>&ldquo;My insurance broker flagged that I didn&rsquo;t have proper risk assessments. Looked at hiring a consultant but the quotes were mad. This was a fraction of the cost and I could do it myself.&rdquo;</p>
          <cite>&mdash; D.K., Manchester</cite>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>&ldquo;The COSHH assessments were the main thing I needed. Was expecting blank forms but they had all the chemical data already filled in, which saved a lot of headaches.&rdquo;</p>
          <cite>&mdash; L.T., Dublin</cite>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>&ldquo;Downloaded the free sample first because I wasn&rsquo;t sure. It was genuinely good so I went for the Pro kit. No regrets.&rdquo;</p>
          <cite>&mdash; M.R., Bristol</cite>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>&ldquo;Needed documents for a council tender that was due in two days. Cut it close but got everything submitted on time. Won the contract too.&rdquo;</p>
          <cite>&mdash; E.P., Leeds</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Homepage FAQ -->
  <section class="section">
    <div class="container" style="max-width: 700px;">
      <h2 class="text-center">Frequently Asked Questions</h2>
      <div class="home-faq">
        <details>
          <summary>Do I need health and safety experience to use these kits?</summary>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(135deg, #eff6ff, #dbeafe);
    padding: 5rem 0 4rem;
    text-align: center;
  }

  .hero-eyebrow {
    font-size: 0.9rem;
    font-weight: 600;
    color: #2563eb;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-size: 2.75rem;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    max-width: 750px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: #4b5563;
    max-width: 620px;
    margin: 0 auto 2rem;
    line-height: 1.65;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .hero-note {
    font-size: 0.85rem;
    color: #6b7280;
    margin-bottom: 0;
  }

  /* Button sizes */
  .btn-lg {
    padding: 0.875rem 2rem;
    font-size: 1.05rem;
  }

  .btn-ghost {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #fff;
    text-decoration: none;
  }

  /* Section subtitle */
  .section-subtitle {
    max-width: 650px;
    margin: 0 auto 2.5rem;
    text-align: center;
    color: #4b5563;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  /* Pain points */
  .pain-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .pain-card {
    padding: 1.5rem;
    border-left: 3px solid #ef4444;
    background: #fef2f2;
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .pain-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
  }

  .pain-card p {
    color: #4b5563;
    font-size: 0.925rem;
    margin-bottom: 0;
    line-height: 1.55;
  }

  /* Solution features */
  .solution-section {
    background: #f9fafb;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .feature {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: #dcfce7;
    color: #16a34a;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .feature h3 {
    font-size: 1.05rem;
    margin-bottom: 0.25rem;
  }

  .feature p {
    color: #4b5563;
    font-size: 0.925rem;
    margin-bottom: 0;
    line-height: 1.5;
  }

  /* Comparison table */
  .comparison-table {
    max-width: 850px;
    margin: 0 auto;
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th, td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
    font-size: 0.925rem;
  }

  th {
    font-weight: 600;
    background: #f9fafb;
  }

  .highlight-row {
    background: #eff6ff;
  }

  /* How it works */
  .how-it-works {
    background: #f9fafb;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  .step {
    text-align: center;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: #2563eb;
    color: #fff;
    font-weight: 700;
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
  }

  .step h3 {
    font-size: 1.05rem;
    margin-bottom: 0.35rem;
  }

  .step p {
    color: #4b5563;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Kit cards */
  .kits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .kit-card {
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.75rem;
    background: #fff;
    position: relative;
  }

  .kit-card-featured {
